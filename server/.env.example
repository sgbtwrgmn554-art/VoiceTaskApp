# Generate VAPID keys once:
# cd server && node -e "import('web-push').then(m => console.log(JSON.stringify(m.default.generateVAPIDKeys(), null, 2)))"
VAPID_PUBLIC_KEY=your_public_key_here
VAPID_PRIVATE_KEY=your_private_key_here
VAPID_EMAIL=mailto:you@example.com

PORT=3001

# Allowed frontend origin (use * for dev, your deployed URL for prod)
FRONTEND_URL=*
